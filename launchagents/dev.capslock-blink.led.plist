<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>dev.capslock-blink.led</string>
  <key>ProgramArguments</key>
  <array><string>__DIR__/capsled.app/Contents/MacOS/capsled</string></array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardErrorPath</key><string>/tmp/capsled.err.log</string>
  <key>StandardOutPath</key><string>/tmp/capsled.out.log</string>
</dict>
</plist>
