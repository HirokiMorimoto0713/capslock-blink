# capslock-blink 設定ファイル
# ~/.capslock-blink/config にコピーして自分の環境に合わせて書き換える。

# Claude Code が同じ Mac 上で動くならこのまま "local" でOK（SSH不要）。
# 別マシン（母艦）で動かす場合は "user@host" を書く（鍵認証で入れること）。
MOTHERSHIP="local"

# flag ファイルが作られるパス（通常このままでOK）。
# ローカルモードではこの Mac 上のパス、リモートモードでは母艦側のパスとして扱われる。
FLAG_PATH="~/.claude/blink-flag"

# Mac ローカルの状態ファイル（capsled と共有。通常このままでOK）。
STATE="/tmp/claude-blink-state"

# 母艦フラグを見に行く間隔（秒）。
INTERVAL="1"

# CapsLock 2回押しによる手動解除の合図ファイル（capsled と共有。通常このままでOK）。
DISMISS="/tmp/claude-blink-dismiss"
